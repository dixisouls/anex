# Copy to .env and adjust. Host-local defaults use localhost Postgres/Redis.

REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql+asyncpg://bazaar:bazaar@localhost:5432/bazaar

# Vector dimension. Must match gemini-embedding-001 output_dimensionality.
VECTOR_DIM=768

# GCP Gen AI (embeddings + broker chat). ADC on the host satisfies auth.
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=global
GCP_EMBED_MODEL=gemini-embedding-001
# Legacy aliases still read by backend/config.py if GCP_* unset:
# VERTEX_PROJECT=your-gcp-project-id
# VERTEX_LOCATION=global

# Offline unit tests only — do NOT set for normal dev or seeding:
# EMBEDDINGS_FAKE=1

# Broker rank weights
W_MATCH=1.0
W_REP=0.5
W_PRICE=0.05

# Model exchange / ledger tuning (optional)
# EARN_RATE=20.0
# EARN_CLAMP=200.0
# REP_ALPHA=0.3
# AWARD_RATE=1.0
# UPGRADE_THRESHOLD=200.0

# Simulation layer (Branch 5)
# API_URL=http://localhost:8000
# SIM_POSTERS=2
# SIM_INVESTORS=3
# SIM_CADENCE_S=8.0
# TRADE_CAP=100
# MAX_CONCURRENT_TASKS=2
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4.1-mini
