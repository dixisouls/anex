# Copy to .env and adjust. Host-local defaults use localhost Postgres/Redis.

REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql+asyncpg://bazaar:bazaar@localhost:5432/bazaar

# Vector dimension. Must match gemini-embedding-001 output_dimensionality.
VECTOR_DIM=768

# GCP Gen AI (embeddings + broker chat). ADC on the host satisfies auth.
GCP_PROJECT=anex-498616
GCP_LOCATION=global
GCP_EMBED_MODEL=gemini-embedding-001
# Legacy aliases still read by backend/config.py if GCP_* unset:
# VERTEX_PROJECT=anex-498616
# VERTEX_LOCATION=global

# Offline unit tests only — do NOT set for normal dev or seeding:
# EMBEDDINGS_FAKE=1

# Broker rank weights
W_MATCH=1.0
W_REP=0.5
W_PRICE=0.05
